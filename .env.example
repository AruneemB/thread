# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
APP_BASE_URL=https://your-app.vercel.app

# --- Database (Turso) ---
TURSO_DATABASE_URL=file:./thread.db
TURSO_AUTH_TOKEN=

# --- GitHub Integration ---
# Get your token at https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=AruneemB/thread

# --- Google AI (Gemini) ---
# Get your keys at https://aistudio.google.com/app/apikey
# Key for the landing page chatbot
GOOGLE_AI_API_KEY_CHAT=
# Key for the /issue command
GOOGLE_AI_API_KEY_ISSUE=

# --- Cron Job Secret ---
CRON_SECRET=

# --- Telegram Web Sign-In ---
# Generate with: openssl rand -hex 32
THREAD_JWT_SECRET=

# --- Settings ---
LOG_LEVEL=info
RENDER_TIMEOUT_MS=30000
STATS_COOLDOWN_SECONDS=600
WEEKLY_DIGEST_ENABLED=true
