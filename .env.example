# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=

# Turso Database Configuration
# Get these from your Turso dashboard at https://turso.tech/
TURSO_DATABASE_URL=file:./thread.db
TURSO_AUTH_TOKEN=

# Application Settings
LOG_LEVEL=info
RENDER_TIMEOUT_MS=30000
STATS_COOLDOWN_SECONDS=600
WEEKLY_DIGEST_ENABLED=true

# Cron Job Secret (pre-generated)
CRON_SECRET=

# Application Base URL (for shareable Threads)
APP_BASE_URL=https://your-app.vercel.app

# Google AI (Gemini) — required for the chatbot on the landing page
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
