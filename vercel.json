{
  "buildCommand": "npm run build",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "src/templates/**"
    },
    "api/cron/digest.ts": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "src/templates/**"
    },
    "api/share/[token].ts": {
      "maxDuration": 10,
      "memory": 256,
      "includeFiles": "src/templates/**"
    },
    "api/save.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/data/[token].ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/metrics.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/chat.ts": {
      "maxDuration": 20,
      "memory": 512,
      "includeFiles": "README.md;docs-thread/**"
    },
    "api/auth/telegram.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/me/chats.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/me/chat/[chatId].ts": {
      "maxDuration": 15,
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/cron/digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
