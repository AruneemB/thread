{
  "name": "thread",
  "version": "1.0.0",
  "type": "module",
  "description": "Every message is a commit. Thread visualizes your Telegram group chats as a contribution graph, tracking streaks, activity patterns, and who keeps the conversation alive.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "webhook:set": "node -e \"fetch(`https://api.telegram.org/bot${process.env.TELEGRAM_BOT_TOKEN}/setWebhook?url=${process.env.VERCEL_URL}/api/webhook`).then(r=>r.json()).then(console.log)\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AruneemB/thread.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AruneemB/thread/issues"
  },
  "homepage": "https://github.com/AruneemB/thread#readme",
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@sparticuz/chromium": "^131.0.0",
    "grammy": "^1.41.1",
    "pino": "^10.3.1",
    "puppeteer-core": "^23.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vercel/node": "^3.2.26",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
